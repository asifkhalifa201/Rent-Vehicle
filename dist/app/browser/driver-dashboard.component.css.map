
      .upload-hint {
        display: inline-block;
        margin-top: 6px;
        padding: 4px 10px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--surface) 86%, var(--primary) 14%);
        color: var(--text) !important;
        font-size: 14px;
        font-weight: 700;
        line-height: 1.35;
      }
    